# EtherCAT Hardware Validation

Interactive Livebook for the current EtherCAT runtime.

This notebook assumes the EL2809 outputs are wired to the matching EL1809 inputs.
It is designed for:

1. startup and runtime validation
2. manual loopback checks
3. latency and throughput measurements
4. realtime-vs-reliable priority checks
5. Distributed Clocks visibility

## Requirements

- Open this notebook from the project root
- Use a Mix project runtime for this repository
- Run with the privileges needed for raw EtherCAT socket access
- Adjust the configuration form before starting the stack

## Current runtime constraints

- High-level `%DomainConfig{}` periods must currently be whole milliseconds
- High-level `%EtherCAT.DC.Config{}` cycle times must currently be whole milliseconds
- `EtherCAT.start/1` domains do not take `logical_base`; the master allocates logical windows automatically
- Runtime faults surface as `EtherCAT.phase() == :recovering`
- Practical minimum cycle is `1 ms`

```elixir
alias EtherCAT.Bus
alias EtherCAT.Bus.Transaction
alias EtherCAT.Domain
alias EtherCAT.Domain.Config, as: DomainConfig
alias EtherCAT.Slave.Config, as: SlaveConfig
alias EtherCAT.Slave.Registers
```

## Interactive Configuration

```elixir
interface_input = Kino.Input.text("Interface", default: "eth1")
backup_interface_input = Kino.Input.text("Backup interface", default: "")
cycle_ms_input = Kino.Input.number("Cycle time (ms)", default: 1)
miss_threshold_input = Kino.Input.number("Miss threshold", default: 500)
startup_timeout_input = Kino.Input.number("Startup timeout (ms)", default: 15_000)
include_thermo_input = Kino.Input.checkbox("Include EL3202", default: true)
loopback_mask_input = Kino.Input.text("Loopback mask", default: "0xFFFF")
dc_enabled_input = Kino.Input.checkbox("Enable DC", default: true)
await_lock_input = Kino.Input.checkbox("Await DC lock", default: false)
lock_threshold_input = Kino.Input.number("DC lock threshold (ns)", default: 100)
lock_timeout_input = Kino.Input.number("DC lock timeout (ms)", default: 5_000)

config_form =
  Kino.Control.form(
    [
      interface: interface_input,
      backup_interface: backup_interface_input,
      cycle_ms: cycle_ms_input,
      miss_threshold: miss_threshold_input,
      startup_timeout_ms: startup_timeout_input,
      include_thermo?: include_thermo_input,
      loopback_mask: loopback_mask_input,
      dc_enabled?: dc_enabled_input,
      await_lock?: await_lock_input,
      lock_threshold_ns: lock_threshold_input,
      lock_timeout_ms: lock_timeout_input
    ],
    submit: "Use configuration"
  )

Kino.render(config_form)
```

```elixir
config_store_key = :ethercat_hardware_validation_config
config_preview = Kino.Frame.new()
Kino.render(config_preview)

Kino.listen(config_form, fn %{data: submitted_config} ->
  parse_mask = fn raw ->
    raw = String.trim(raw)

    cond do
      raw == "" ->
        0

      String.starts_with?(raw, "0x") or String.starts_with?(raw, "0X") ->
        String.slice(raw, 2..-1//1)
        |> String.upcase()
        |> Integer.parse(16)
        |> case do
          {value, ""} -> value
          _ -> raise ArgumentError, "invalid loopback mask: #{inspect(raw)}"
        end

      true ->
        case Integer.parse(raw) do
          {value, ""} -> value
          _ -> raise ArgumentError, "invalid loopback mask: #{inspect(raw)}"
        end
    end
  end

  cycle_ms = max(1, submitted_config.cycle_ms)
  cycle_time_us = cycle_ms * 1_000
  loopback_mask = parse_mask.(submitted_config.loopback_mask)

  backup_interface =
    case String.trim(submitted_config.backup_interface) do
      "" -> nil
      value -> value
    end

  dc_config =
    if submitted_config.dc_enabled? do
      %EtherCAT.DC.Config{
        cycle_ns: cycle_ms * 1_000_000,
        await_lock?: submitted_config.await_lock?,
        lock_threshold_ns: submitted_config.lock_threshold_ns,
        lock_timeout_ms: submitted_config.lock_timeout_ms
      }
    else
      nil
    end

  config = %{
    interface: submitted_config.interface,
    backup_interface: backup_interface,
    domain_id: :main,
    cycle_ms: cycle_ms,
    cycle_time_us: cycle_time_us,
    miss_threshold: submitted_config.miss_threshold,
    startup_timeout_ms: submitted_config.startup_timeout_ms,
    include_thermo?: submitted_config.include_thermo?,
    loopback_mask: loopback_mask,
    dc: dc_config,
    coupler_name: :coupler,
    sensor_name: :sensor,
    valve_name: :valve,
    thermo_name: :thermo
  }

  :persistent_term.put(config_store_key, config)
  Kino.Frame.render(config_preview, Kino.Tree.new(config))
end)

:ok
```

```elixir
case :persistent_term.get(:ethercat_hardware_validation_config, nil) do
  nil ->
    Kino.Markdown.new("Submit the configuration form first.")

  config ->
    Kino.render(Kino.Tree.new(config))
    config
end
```

## Driver Definitions

```elixir
defmodule Example.EL1809 do
  @behaviour EtherCAT.Slave.Driver

  @impl true
  def process_data_model(_config) do
    [
      ch1: 0x1A00, ch2: 0x1A01, ch3: 0x1A02, ch4: 0x1A03,
      ch5: 0x1A04, ch6: 0x1A05, ch7: 0x1A06, ch8: 0x1A07,
      ch9: 0x1A08, ch10: 0x1A09, ch11: 0x1A0A, ch12: 0x1A0B,
      ch13: 0x1A0C, ch14: 0x1A0D, ch15: 0x1A0E, ch16: 0x1A0F
    ]
  end

  @impl true
  def encode_signal(_signal, _config, _value), do: <<>>

  @impl true
  def decode_signal(_signal, _config, <<_::7, bit::1>>), do: bit
  def decode_signal(_signal, _config, _raw), do: 0
end

defmodule Example.EL2809 do
  @behaviour EtherCAT.Slave.Driver

  @impl true
  def process_data_model(_config) do
    [
      ch1: 0x1600, ch2: 0x1601, ch3: 0x1602, ch4: 0x1603,
      ch5: 0x1604, ch6: 0x1605, ch7: 0x1606, ch8: 0x1607,
      ch9: 0x1608, ch10: 0x1609, ch11: 0x160A, ch12: 0x160B,
      ch13: 0x160C, ch14: 0x160D, ch15: 0x160E, ch16: 0x160F
    ]
  end

  @impl true
  def encode_signal(_signal, _config, value), do: <<value::8>>

  @impl true
  def decode_signal(_signal, _config, _raw), do: nil
end

defmodule Example.EL3202 do
  @behaviour EtherCAT.Slave.Driver

  @impl true
  def process_data_model(_config) do
    [channel1: 0x1A00, channel2: 0x1A01]
  end

  @impl true
  def mailbox_config(_config) do
    [
      {:sdo_download, 0x8000, 0x19, <<8::16-little>>},
      {:sdo_download, 0x8010, 0x19, <<8::16-little>>}
    ]
  end

  @impl true
  def encode_signal(_signal, _config, _value), do: <<>>

  @impl true
  def decode_signal(:channel1, _config, <<
        _::1,
        error::1,
        _::2,
        _::2,
        overrange::1,
        underrange::1,
        toggle::1,
        state::1,
        _::6,
        value::16-little
      >>) do
    %{
      ohms: value / 16.0,
      overrange: overrange == 1,
      underrange: underrange == 1,
      error: error == 1,
      invalid: state == 1,
      toggle: toggle
    }
  end

  def decode_signal(:channel2, _config, <<
        _::1,
        error::1,
        _::2,
        _::2,
        overrange::1,
        underrange::1,
        toggle::1,
        state::1,
        _::6,
        value::16-little
      >>) do
    %{
      ohms: value / 16.0,
      overrange: overrange == 1,
      underrange: underrange == 1,
      error: error == 1,
      invalid: state == 1,
      toggle: toggle
    }
  end

  def decode_signal(_signal, _config, _raw), do: nil
end
```

## Helper Modules

```elixir
defmodule Example.Hardware.Observer do
  use GenServer

  @name __MODULE__
  @channels Enum.map(1..16, &:"ch#{&1}")

  def start_link(opts) do
    GenServer.start_link(__MODULE__, opts, name: @name)
  end

  def stop do
    case Process.whereis(@name) do
      nil -> :ok
      pid -> GenServer.stop(pid, :normal)
    end
  end

  def snapshot, do: GenServer.call(@name, :snapshot)

  def reset, do: GenServer.call(@name, :reset)

  def await_channel(channel, value, timeout_ms) do
    try do
      GenServer.call(@name, {:await_channel, channel, value}, timeout_ms)
    catch
      :exit, {:timeout, _} -> {:error, :timeout}
    end
  end

  def await_mask(mask, timeout_ms) do
    try do
      GenServer.call(@name, {:await_mask, mask}, timeout_ms)
    catch
      :exit, {:timeout, _} -> {:error, :timeout}
    end
  end

  @impl true
  def init(opts) do
    sensor_name = Keyword.fetch!(opts, :sensor_name)
    Enum.each(@channels, &EtherCAT.subscribe(sensor_name, &1, self()))

    {:ok,
     %{
       sensor_name: sensor_name,
       bits: Enum.into(@channels, %{}, &{&1, 0}),
       updated_at: Enum.into(@channels, %{}, &{&1, nil}),
       mask_updated_at: nil,
       waiters: []
     }}
  end

  @impl true
  def handle_call(:snapshot, _from, state) do
    {:reply,
     %{bits: state.bits, mask: current_mask(state.bits), mask_updated_at: state.mask_updated_at},
     state}
  end

  def handle_call(:reset, _from, state) do
    {:reply,
     :ok,
     %{state | updated_at: Enum.into(@channels, %{}, &{&1, nil}), mask_updated_at: nil, waiters: []}}
  end

  def handle_call({:await_channel, channel, value}, from, state) do
    ts = Map.fetch!(state.updated_at, channel)
    current_value = Map.fetch!(state.bits, channel)

    if is_integer(ts) and current_value == value do
      {:reply, {:ok, ts}, state}
    else
      waiter = %{type: :channel, from: from, channel: channel, value: value}
      {:noreply, %{state | waiters: [waiter | state.waiters]}}
    end
  end

  def handle_call({:await_mask, mask}, from, state) do
    if is_integer(state.mask_updated_at) and current_mask(state.bits) == mask do
      {:reply, {:ok, state.mask_updated_at}, state}
    else
      waiter = %{type: :mask, from: from, mask: mask}
      {:noreply, %{state | waiters: [waiter | state.waiters]}}
    end
  end

  @impl true
  def handle_info({:ethercat, :signal, sensor_name, channel, value}, %{sensor_name: sensor_name} = state) do
    now = System.monotonic_time()

    new_state = %{
      state
      | bits: Map.put(state.bits, channel, value),
        updated_at: Map.put(state.updated_at, channel, now),
        mask_updated_at: now
    }

    {:noreply, flush_waiters(new_state)}
  end

  def handle_info(_msg, state), do: {:noreply, state}

  defp flush_waiters(state) do
    {reply_now, keep} =
      Enum.split_with(state.waiters, fn waiter ->
        waiter_ready?(waiter, state)
      end)

    Enum.each(reply_now, fn waiter ->
      GenServer.reply(waiter.from, waiter_reply(waiter, state))
    end)

    %{state | waiters: keep}
  end

  defp waiter_ready?(%{type: :channel, channel: channel, value: value}, state) do
    is_integer(Map.fetch!(state.updated_at, channel)) and Map.fetch!(state.bits, channel) == value
  end

  defp waiter_ready?(%{type: :mask, mask: mask}, state) do
    is_integer(state.mask_updated_at) and current_mask(state.bits) == mask
  end

  defp waiter_reply(%{type: :channel, channel: channel}, state) do
    {:ok, Map.fetch!(state.updated_at, channel)}
  end

  defp waiter_reply(%{type: :mask}, state) do
    {:ok, state.mask_updated_at}
  end

  defp current_mask(bits) do
    Enum.reduce(@channels, 0, fn channel, acc ->
      acc + Map.get(bits, channel, 0) * channel_weight(channel)
    end)
  end

  defp channel_weight(channel) do
    <<"ch", digits::binary>> = Atom.to_string(channel)
    Integer.pow(2, String.to_integer(digits) - 1)
  end
end

defmodule Example.Hardware.Telemetry do
  use GenServer

  @name __MODULE__

  @events [
    [:ethercat, :domain, :cycle, :done],
    [:ethercat, :domain, :cycle, :missed],
    [:ethercat, :bus, :submission, :expired],
    [:ethercat, :bus, :dispatch, :sent],
    [:ethercat, :dc, :sync_diff, :observed],
    [:ethercat, :dc, :lock, :changed]
  ]

  def start_link(opts) do
    GenServer.start_link(__MODULE__, opts, name: @name)
  end

  def stop do
    case Process.whereis(@name) do
      nil -> :ok
      pid -> GenServer.stop(pid, :normal)
    end
  end

  def snapshot, do: GenServer.call(@name, :snapshot)
  def reset, do: GenServer.call(@name, :reset)

  @impl true
  def init(opts) do
    domain_id = Keyword.fetch!(opts, :domain_id)
    handler_id = "hardware-validation-#{System.unique_integer([:positive, :monotonic])}"
    :ok = :telemetry.attach_many(handler_id, @events, &__MODULE__.handle_event/4, self())
    {:ok, new_state(handler_id, domain_id)}
  end

  @impl true
  def terminate(_reason, state) do
    :telemetry.detach(state.handler_id)
    :ok
  end

  @impl true
  def handle_call(:snapshot, _from, state) do
    {:reply,
     %{
       domain_cycle_us: Enum.reverse(state.domain_cycle_us_rev),
       domain_missed: state.domain_missed,
       submission_expired: state.submission_expired,
       dispatch: state.dispatch,
       dc_sync_diffs_ns: Enum.reverse(state.dc_sync_diffs_ns_rev),
       dc_lock_changes: Enum.reverse(state.dc_lock_changes_rev)
     }, state}
  end

  def handle_call(:reset, _from, state) do
    {:reply, :ok, reset_state(state)}
  end

  @impl true
  def handle_info(
        {:telemetry_event, [:ethercat, :domain, :cycle, :done], %{duration_us: duration_us}, %{domain: domain}},
        %{domain_id: domain} = state
      ) do
    {:noreply, %{state | domain_cycle_us_rev: [duration_us | state.domain_cycle_us_rev]}}
  end

  def handle_info(
        {:telemetry_event, [:ethercat, :domain, :cycle, :missed], _measurements, %{domain: domain}},
        %{domain_id: domain} = state
      ) do
    {:noreply, %{state | domain_missed: state.domain_missed + 1}}
  end

  def handle_info(
        {:telemetry_event, [:ethercat, :bus, :submission, :expired], _measurements, _metadata},
        state
      ) do
    {:noreply, %{state | submission_expired: state.submission_expired + 1}}
  end

  def handle_info(
        {:telemetry_event, [:ethercat, :bus, :dispatch, :sent], measurements, %{class: class}},
        state
      ) do
    current = Map.fetch!(state.dispatch, class)

    updated = %{
      current
      | frames: current.frames + 1,
        transactions: current.transactions + measurements.transaction_count,
        datagrams: current.datagrams + measurements.datagram_count
    }

    {:noreply, %{state | dispatch: Map.put(state.dispatch, class, updated)}}
  end

  def handle_info(
        {:telemetry_event, [:ethercat, :dc, :sync_diff, :observed], %{max_sync_diff_ns: value}, _metadata},
        state
      ) do
    {:noreply, %{state | dc_sync_diffs_ns_rev: [value | state.dc_sync_diffs_ns_rev]}}
  end

  def handle_info(
        {:telemetry_event, [:ethercat, :dc, :lock, :changed], _measurements, metadata},
        state
      ) do
    event = %{
      from: metadata.from,
      to: metadata.to,
      max_sync_diff_ns: metadata.max_sync_diff_ns
    }

    {:noreply, %{state | dc_lock_changes_rev: [event | state.dc_lock_changes_rev]}}
  end

  def handle_info({:telemetry_event, _event, _measurements, _metadata}, state), do: {:noreply, state}

  def handle_event(event, measurements, metadata, pid) do
    send(pid, {:telemetry_event, event, measurements, metadata})
  end

  defp new_state(handler_id, domain_id) do
    %{
      handler_id: handler_id,
      domain_id: domain_id,
      domain_cycle_us_rev: [],
      domain_missed: 0,
      submission_expired: 0,
      dispatch: %{
        realtime: %{frames: 0, transactions: 0, datagrams: 0},
        reliable: %{frames: 0, transactions: 0, datagrams: 0}
      },
      dc_sync_diffs_ns_rev: [],
      dc_lock_changes_rev: []
    }
  end

  defp reset_state(state) do
    %{state |
      domain_cycle_us_rev: [],
      domain_missed: 0,
      submission_expired: 0,
      dispatch: %{
        realtime: %{frames: 0, transactions: 0, datagrams: 0},
        reliable: %{frames: 0, transactions: 0, datagrams: 0}
      },
      dc_sync_diffs_ns_rev: [],
      dc_lock_changes_rev: []}
  end
end

defmodule Example.Hardware do
  alias EtherCAT.Bus
  alias EtherCAT.Bus.Transaction
  alias EtherCAT.Domain
  alias EtherCAT.Domain.Config, as: DomainConfig
  alias EtherCAT.Slave.Config, as: SlaveConfig
  alias EtherCAT.Slave.Registers

  @channels Enum.map(1..16, &:"ch#{&1}")

  def start_stack(config) do
    stop_stack()
    Process.sleep(200)

    start_opts =
      [
        interface: config.interface,
        domains: [
          %DomainConfig{
            id: config.domain_id,
            cycle_time_us: config.cycle_time_us,
            miss_threshold: config.miss_threshold
          }
        ],
        slaves: slave_configs(config),
        dc: config.dc
      ]
      |> maybe_put(:backup_interface, config.backup_interface)

    :ok = EtherCAT.start(start_opts)
    :ok = EtherCAT.await_running(config.startup_timeout_ms)

    {:ok, _observer} = Example.Hardware.Observer.start_link(sensor_name: config.sensor_name)
    {:ok, _telemetry} = Example.Hardware.Telemetry.start_link(domain_id: config.domain_id)

    Process.sleep(config.cycle_ms * 3)

    %{
      config: config,
      stations: station_map(),
      dc_status: EtherCAT.dc_status(),
      reference_clock: EtherCAT.reference_clock()
    }
  end

  def stop_stack do
    Example.Hardware.Telemetry.stop()
    Example.Hardware.Observer.stop()
    EtherCAT.stop()
    :ok
  end

  def runtime_snapshot(config) do
    {:ok, domain_stats} = Domain.stats(config.domain_id)

    %{
      master_state: EtherCAT.state(),
      phase: EtherCAT.phase(),
      last_failure: EtherCAT.last_failure(),
      slaves: EtherCAT.slaves(),
      reference_clock: EtherCAT.reference_clock(),
      dc_status: EtherCAT.dc_status(),
      domain: domain_stats,
      observer: Example.Hardware.Observer.snapshot(),
      telemetry: Example.Hardware.Telemetry.snapshot(),
      thermo:
        if(config.include_thermo?,
          do: %{
            channel1: EtherCAT.read_input(config.thermo_name, :channel1),
            channel2: EtherCAT.read_input(config.thermo_name, :channel2)
          },
          else: :not_enabled
        )
    }
  end

  def write_channel(config, channel, value) do
    :ok = EtherCAT.write_output(config.valve_name, channel, value)
    Process.sleep(config.cycle_ms * 2)

    %{
      channel: channel,
      written: value,
      observed: EtherCAT.read_input(config.sensor_name, channel),
      observer: Example.Hardware.Observer.snapshot()
    }
  end

  def write_mask(config, mask, timeout_ms) do
    :ok = Example.Hardware.Observer.reset()
    started_at = System.monotonic_time()
    :ok = set_mask(config.valve_name, mask)

    case await_mask_value(config, mask, timeout_ms) do
      {:ok, observed_at, source} ->
        %{
          expected_mask: mask,
          source: source,
          latency_us: duration_us(observed_at - started_at),
          observed_mask: read_mask(config.sensor_name),
          observer: Example.Hardware.Observer.snapshot()
        }

      {:error, :timeout} ->
        %{
          expected_mask: mask,
          error: :timeout,
          observed_mask: read_mask(config.sensor_name),
          observer: Example.Hardware.Observer.snapshot()
        }
    end
  end

  def single_channel_latency(config, samples, timeout_ms) do
    channel = :ch1
    :ok = Example.Hardware.Observer.reset()
    {:ok, prime} = prime_loopback(config, timeout_ms)

    {latencies_rev, timeouts, sources} =
      Enum.reduce(1..samples, {[], 0, %{subscription: 0, poll: 0}}, fn idx, {acc, timeout_count, source_counts} ->
        expected = rem(idx, 2)
        started_at = System.monotonic_time()
        :ok = EtherCAT.write_output(config.valve_name, channel, expected)

        case await_channel_value(config, channel, expected, timeout_ms) do
          {:ok, observed_at, source} ->
            {
              [duration_us(observed_at - started_at) | acc],
              timeout_count,
              Map.update!(source_counts, source, &(&1 + 1))
            }

          {:error, :timeout} ->
            {acc, timeout_count + 1, source_counts}
        end
      end)

    %{
      benchmark: :single_channel_latency,
      channel: channel,
      samples: samples,
      successful_samples: length(latencies_rev),
      timeout_count: timeouts,
      source_counts: sources,
      prime: prime,
      latency_us: summarize_us(Enum.reverse(latencies_rev))
    }
  end

  def full_width_loopback(config, samples, timeout_ms) do
    {:ok, prime} = prime_loopback(config, timeout_ms)
    :ok = Example.Hardware.Telemetry.reset()

    {:ok, before} = Domain.stats(config.domain_id)
    wall_started_at = System.monotonic_time()

    {latencies_rev, timeouts, sources} =
      Enum.reduce(1..samples, {[], 0, %{subscription: 0, poll: 0}}, fn idx, {acc, timeout_count, source_counts} ->
        expected_mask = if rem(idx, 2) == 1, do: config.loopback_mask, else: 0
        started_at = System.monotonic_time()
        :ok = set_mask(config.valve_name, expected_mask)

        case await_mask_value(config, expected_mask, timeout_ms) do
          {:ok, observed_at, source} ->
            {
              [duration_us(observed_at - started_at) | acc],
              timeout_count,
              Map.update!(source_counts, source, &(&1 + 1))
            }

          {:error, :timeout} ->
            {acc, timeout_count + 1, source_counts}
        end
      end)

    wall_us = duration_us(System.monotonic_time() - wall_started_at)
    {:ok, after_stats} = Domain.stats(config.domain_id)
    telemetry = Example.Hardware.Telemetry.snapshot()
    latencies_us = Enum.reverse(latencies_rev)
    successful = length(latencies_us)

    %{
      benchmark: :full_width_loopback,
      samples: samples,
      successful_patterns: successful,
      timeout_count: timeouts,
      source_counts: sources,
      prime: prime,
      loopback_mask: config.loopback_mask,
      wall_ms: wall_us / 1_000,
      patterns_per_s: safe_rate(successful, wall_us),
      channel_transitions_per_s: safe_rate(successful * enabled_channel_count(config.loopback_mask), wall_us),
      latency_us: summarize_us(latencies_us),
      domain: %{
        cycle_count: after_stats.cycle_count - before.cycle_count,
        total_miss_count: after_stats.total_miss_count - before.total_miss_count,
        expected_wkc: after_stats.expected_wkc,
        image_size: after_stats.image_size,
        cycle_latency_us: summarize_us(telemetry.domain_cycle_us),
        telemetry_misses: telemetry.domain_missed
      },
      dispatch: telemetry.dispatch,
      dc: %{sync_diff_ns: summarize_us(telemetry.dc_sync_diffs_ns), lock_changes: telemetry.dc_lock_changes}
    }
  end

  def priority_stress(config, probe_samples, reliable_workers, reliable_flood_ms, deadline_us) do
    :ok = Example.Hardware.Telemetry.reset()

    bus = EtherCAT.bus()
    stations = station_map()
    probe_station = pick_probe_station(config, stations)
    started_at = System.monotonic_time()

    workers =
      Enum.map(1..reliable_workers, fn _idx ->
        Task.async(fn ->
          reliable_flood_loop(bus, probe_station, reliable_flood_ms)
        end)
      end)

    {latencies_rev, errors_rev} =
      Enum.reduce(1..probe_samples, {[], []}, fn _idx, {latencies_acc, errors_acc} ->
        probe_started_at = System.monotonic_time()

        case Bus.transaction(bus, Transaction.fprd(probe_station, Registers.al_status()), deadline_us) do
          {:ok, [%{wkc: wkc}]} when wkc == 1 ->
            {[duration_us(System.monotonic_time() - probe_started_at) | latencies_acc], errors_acc}

          {:ok, replies} ->
            {latencies_acc, [{:unexpected_reply, replies} | errors_acc]}

          {:error, reason} ->
            {latencies_acc, [reason | errors_acc]}
        end
      end)

    Enum.each(workers, &Task.await(&1, reliable_flood_ms + 1_000))

    wall_us = duration_us(System.monotonic_time() - started_at)
    telemetry = Example.Hardware.Telemetry.snapshot()

    %{
      benchmark: :priority_stress,
      probe_station: probe_station,
      probe_samples: probe_samples,
      realtime_deadline_us: deadline_us,
      reliable_workers: reliable_workers,
      reliable_flood_ms: reliable_flood_ms,
      wall_ms: wall_us / 1_000,
      probe_latency_us: summarize_us(Enum.reverse(latencies_rev)),
      successful_probes: length(latencies_rev),
      errors: Enum.reverse(errors_rev),
      dispatch: telemetry.dispatch,
      submission_expired: telemetry.submission_expired,
      domain_cycle_us: summarize_us(telemetry.domain_cycle_us),
      domain_missed: telemetry.domain_missed,
      dc: %{sync_diff_ns: summarize_us(telemetry.dc_sync_diffs_ns), lock_changes: telemetry.dc_lock_changes}
    }
  end

  defp slave_configs(config) do
    base = [
      %SlaveConfig{name: config.coupler_name},
      %SlaveConfig{name: config.sensor_name, driver: Example.EL1809, process_data: {:all, config.domain_id}},
      %SlaveConfig{name: config.valve_name, driver: Example.EL2809, process_data: {:all, config.domain_id}}
    ]

    if config.include_thermo? do
      base ++ [
        %SlaveConfig{name: config.thermo_name, driver: Example.EL3202, process_data: {:all, config.domain_id}}
      ]
    else
      base
    end
  end

  defp maybe_put(opts, _key, nil), do: opts
  defp maybe_put(opts, key, value), do: Keyword.put(opts, key, value)

  defp station_map do
    EtherCAT.slaves()
    |> Enum.into(%{}, fn %{name: name, station: station} -> {name, station} end)
  end

  defp pick_probe_station(config, stations) do
    Map.get(stations, config.sensor_name) || Map.get(stations, config.coupler_name) || 0x1000
  end

  defp reliable_flood_loop(bus, station, duration_ms) do
    deadline = System.monotonic_time(:millisecond) + duration_ms
    do_reliable_flood_loop(bus, station, deadline)
  end

  defp do_reliable_flood_loop(bus, station, deadline) do
    if System.monotonic_time(:millisecond) >= deadline do
      :ok
    else
      _ = Bus.transaction(bus, Transaction.fprd(station, Registers.al_status()))
      do_reliable_flood_loop(bus, station, deadline)
    end
  end

  defp prime_loopback(config, timeout_ms) do
    :ok = Example.Hardware.Observer.reset()

    case write_mask(config, 0, timeout_ms) do
      %{error: :timeout} = failure ->
        {:error, {:prime_failed, :low, failure}}

      low ->
        case write_mask(config, config.loopback_mask, timeout_ms) do
          %{error: :timeout} = failure ->
            {:error, {:prime_failed, :high, failure}}

          high ->
            {:ok, %{low: low, high: high}}
        end
    end
  end

  defp await_channel_value(config, channel, expected, timeout_ms) do
    case Example.Hardware.Observer.await_channel(channel, expected, timeout_ms) do
      {:ok, ts} -> {:ok, ts, :subscription}
      {:error, :timeout} -> poll_channel(config, channel, expected, timeout_ms)
    end
  end

  defp await_mask_value(config, expected_mask, timeout_ms) do
    case Example.Hardware.Observer.await_mask(expected_mask, timeout_ms) do
      {:ok, ts} -> {:ok, ts, :subscription}
      {:error, :timeout} -> poll_mask(config, expected_mask, timeout_ms)
    end
  end

  defp poll_channel(config, channel, expected, timeout_ms) do
    deadline = System.monotonic_time(:millisecond) + timeout_ms
    do_poll_channel(config, channel, expected, deadline)
  end

  defp do_poll_channel(config, channel, expected, deadline) do
    case EtherCAT.read_input(config.sensor_name, channel) do
      {:ok, ^expected} -> {:ok, System.monotonic_time(), :poll}
      _ ->
        if System.monotonic_time(:millisecond) >= deadline do
          {:error, :timeout}
        else
          Process.sleep(1)
          do_poll_channel(config, channel, expected, deadline)
        end
    end
  end

  defp poll_mask(config, expected_mask, timeout_ms) do
    deadline = System.monotonic_time(:millisecond) + timeout_ms
    do_poll_mask(config, expected_mask, deadline)
  end

  defp do_poll_mask(config, expected_mask, deadline) do
    if read_mask(config.sensor_name) == expected_mask do
      {:ok, System.monotonic_time(), :poll}
    else
      if System.monotonic_time(:millisecond) >= deadline do
        {:error, :timeout}
      else
        Process.sleep(1)
        do_poll_mask(config, expected_mask, deadline)
      end
    end
  end

  defp read_mask(sensor_name) do
    Enum.reduce(@channels, 0, fn channel, acc ->
      bit =
        case EtherCAT.read_input(sensor_name, channel) do
          {:ok, value} when value in [0, 1] -> value
          _ -> 0
        end

      acc + bit * channel_weight(channel)
    end)
  end

  defp set_mask(valve_name, mask) do
    Enum.each(@channels, fn channel ->
      value = if channel_enabled?(mask, channel), do: 1, else: 0
      :ok = EtherCAT.write_output(valve_name, channel, value)
    end)

    :ok
  end

  defp channel_enabled?(mask, channel) do
    weight = channel_weight(channel)
    rem(div(mask, weight), 2) == 1
  end

  defp enabled_channel_count(mask) do
    Enum.count(@channels, &channel_enabled?(mask, &1))
  end

  defp channel_weight(channel) do
    <<"ch", digits::binary>> = Atom.to_string(channel)
    Integer.pow(2, String.to_integer(digits) - 1)
  end

  defp duration_us(native_delta) when is_integer(native_delta) do
    System.convert_time_unit(native_delta, :native, :microsecond)
  end

  defp safe_rate(0, _wall_us), do: 0.0
  defp safe_rate(_count, 0), do: 0.0
  defp safe_rate(count, wall_us), do: Float.round(count * 1_000_000 / wall_us, 2)

  defp summarize_us([]) do
    %{count: 0, min_us: nil, p50_us: nil, p95_us: nil, p99_us: nil, max_us: nil, mean_us: nil}
  end

  defp summarize_us(values) do
    sorted = Enum.sort(values)
    count = length(sorted)
    sum = Enum.sum(sorted)

    %{
      count: count,
      min_us: hd(sorted),
      p50_us: percentile(sorted, 0.50),
      p95_us: percentile(sorted, 0.95),
      p99_us: percentile(sorted, 0.99),
      max_us: List.last(sorted),
      mean_us: Float.round(sum / count, 1)
    }
  end

  defp percentile(sorted, ratio) do
    index = max(0, min(length(sorted) - 1, ceil(length(sorted) * ratio) - 1))
    Enum.at(sorted, index)
  end
end
```

## Start or Restart the Stack

```elixir
start_stack_button = Kino.Control.button("Start or restart the stack")
start_stack_frame = Kino.Frame.new()

Kino.render(start_stack_button)
Kino.render(start_stack_frame)

Kino.Frame.render(start_stack_frame, Kino.Markdown.new("Click to start or restart the EtherCAT stack."))

Kino.listen(start_stack_button, fn _event ->
  current_config = :persistent_term.get(:ethercat_hardware_validation_config)
  session = Example.Hardware.start_stack(current_config)
  Kino.Frame.render(start_stack_frame, Kino.Tree.new(session))
end)

:ok
```

## Stop the Stack

```elixir
:ok = Example.Hardware.stop_stack()
Kino.Markdown.new("Stopped EtherCAT, observer, and telemetry runtime.")
```

