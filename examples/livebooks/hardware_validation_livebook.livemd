## Manual Single-Channel Write

```elixir
manual_channel_form =
  Kino.Control.form(
    [
      channel: Kino.Input.select("Channel", Enum.map(1..16, fn n -> {"ch#{n}", String.to_atom("ch#{n}")} end), default: :ch1),
      value: Kino.Input.select("Value", [{"0", 0}, {"1", 1}], default: 1)
    ],
    submit: "Write channel"
  )

Kino.render(manual_channel_form)
```

```elixir
manual_channel_frame = Kino.Frame.new()

Kino.render(manual_channel_frame)
Kino.Frame.render(manual_channel_frame, Kino.Markdown.new("Submit the form to write one output bit."))

Kino.listen(manual_channel_form, fn %{data: manual_channel} ->
  current_config = :persistent_term.get(:ethercat_hardware_validation_config)
  result = Example.Hardware.write_channel(current_config, manual_channel.channel, manual_channel.value)
  Kino.Frame.render(manual_channel_frame, Kino.Tree.new(result))
end)

:ok
```

## Manual Full-Mask Write

```elixir
manual_mask_form =
  Kino.Control.form(
    [
      mask: Kino.Input.text("Mask", default: "0x0000"),
      timeout_ms: Kino.Input.number("Timeout (ms)", default: max(config.cycle_ms * 10, 100))
    ],
    submit: "Write mask"
  )

Kino.render(manual_mask_form)
```

```elixir
manual_mask_frame = Kino.Frame.new()

Kino.render(manual_mask_frame)
Kino.Frame.render(manual_mask_frame, Kino.Markdown.new("Submit the form to write the full 16-bit loopback mask."))

Kino.listen(manual_mask_form, fn %{data: manual_mask} ->
  mask =
    case String.trim(manual_mask.mask) do
      raw ->
        cond do
          String.starts_with?(raw, "0x") or String.starts_with?(raw, "0X") ->
            raw |> String.slice(2..-1//1) |> Integer.parse(16) |> elem(0)

          true ->
            raw |> Integer.parse() |> elem(0)
        end
    end

  current_config = :persistent_term.get(:ethercat_hardware_validation_config)
  result = Example.Hardware.write_mask(current_config, mask, manual_mask.timeout_ms)
  Kino.Frame.render(manual_mask_frame, Kino.Tree.new(result))
end)

:ok
```

